    B --> B1[ファンネル分析チャート]
    B --> B2[ヒートマップ表示]
    B --> B3[セッション録画再生]
    B --> B4[離脱ポイント詳細テーブル]
    
    B1 --> D{期間フィルタ選択}
    B2 --> D
    B3 --> D
    B4 --> D
    
    D --> E[セグメント別表示]
    E --> F[異常値アラート]
    
    C --> C1[課題一覧テーブル]
    C --> C2[優先度マトリクス表示]
    C --> C3[ROI計算機能]
    C --> C4[改善提案入力フォーム]
    
    C1 --> G{ドラッグ&ドロップ操作}
    G --> H[優先順位調整]
    H --> I[評価軸重み付け変更]
    
    C4 --> J[改善提案保存]
    J --> A
    
    A --> K[CSVエクスポート]
    B --> L[データフィルタリング]
    C --> M[優先度保存]
    
    M --> A
    K --> N[ファイルダウンロード]
